{"version":3,"kind":"Article","sha256":"1efba54aa86d441281ee7bede7481839fd8506f015c365961ef6744928fc4f67","slug":"hydro","location":"/hydro.md","dependencies":[],"frontmatter":{"title":"Introduction to the Hydrology Workflow","content_includes_title":false,"github":"https://github.com/whitschroder/gis","keywords":["GIS","archaeology"],"numbering":{"title":{"offset":1}},"thumbnail":"/flowacc-599cb3bbff0b77d5afb5d3407c6bad30.jpg","exports":[{"format":"md","filename":"hydro.md","url":"/hydro-363c5db8022d9744a42916f8b5fb8eaf.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"In order to conduct several hydrological analyses in ArcGIS Pro, we first have to follow a basic hydrology workflow to generate the appropriate input data for modelling. The general workflow consists of starting with an input digital elevation model and:","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"HD7Yq6fk8c"}],"key":"s1K1k9OdZf"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":5,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Filling pits","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"Zd2XCovz9b"}],"key":"AendjplCBc"}],"key":"h2m32spvOE"},{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Generating a Flow Direction raster","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"RrtANj7AKO"}],"key":"gjI41EnrdX"}],"key":"Urg3cORyXp"},{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Generating a Flow Accumulation raster","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"Wl13oql1ik"}],"key":"D0cCGSFx5C"}],"key":"Jk9hXvqDfZ"}],"key":"uJXmt3uuMt"},{"type":"heading","depth":2,"position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Fill","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"uhAlOlRQAW"}],"identifier":"fill","label":"Fill","html_id":"fill","implicit":true,"key":"Xg9tdh53rn"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"Before conducting a hydrological analysis, DEM data must be prepared. DEM data can have several errors related to the interpolation of elevation data, namely pits produced by extreme low points. These pits must be removed; otherwise, a hydrological analysis would direct all streams to these pits. In certain landscapes, these pits may actually be real features. Thus, care must be taken when filling in pits to ensure that real features are not lost in the process.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"gxINhIuAB3"}],"key":"ehCcS8nDUz"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"The ","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"JMaY2Xs824"},{"type":"link","url":"https://pro.arcgis.com/en/pro-app/3.4/tool-reference/spatial-analyst/fill.htm","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Fill tool","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"JKoVv0otOM"}],"urlSource":"https://pro.arcgis.com/en/pro-app/3.4/tool-reference/spatial-analyst/fill.htm","key":"Pjd0IoFiFE"},{"type":"text","value":" takes a DEM as input, identifies sinks, and then fills in these sinks using additional interpolation. An optional Z limit can be defined to limit the size of sinks that are filled in. Larger values will fill more sinks, while smaller values will fill fewer sinks. If left blank, all sinks will be filled. Best practice is to run the Fill tool with the Z limit setting left blank, assess the results from later tools, and if necessary, run the Fill tool again with a high Z limit (e.g., 100 m), and iterate through decreasing values.","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"Y2l96TNwPj"}],"key":"QhxsJISMGe"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Another optional step is to smooth the input DEM, using the ","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"LwrHYSjblt"},{"type":"link","url":"https://pro.arcgis.com/en/pro-app/3.4/tool-reference/spatial-analyst/focal-statistics.htm","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Focal Statistics tool","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"zv2CGDatMq"}],"urlSource":"https://pro.arcgis.com/en/pro-app/3.4/tool-reference/spatial-analyst/focal-statistics.htm","key":"kPvuWT7u1H"},{"type":"text","value":" set to mean. This tool may be iterated several times to produce smoother surfaces as needed. This step is generally needed with higher resolution DEM data.","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"PH2FBUFJB2"}],"key":"vLP9xhJuGx"},{"type":"heading","depth":2,"position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Flow Direction","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"Gno90J5U0a"}],"identifier":"flow-direction","label":"Flow Direction","html_id":"flow-direction","implicit":true,"key":"QraBxBuyv8"},{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"The ","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"RsMUdFBHir"},{"type":"link","url":"https://pro.arcgis.com/en/pro-app/3.4/tool-reference/spatial-analyst/flow-direction.htm","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Flow Direction tool","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"yA3hnMpUAS"}],"urlSource":"https://pro.arcgis.com/en/pro-app/3.4/tool-reference/spatial-analyst/flow-direction.htm","key":"k5Bwpk6tMt"},{"type":"text","value":" creates a raster representing the direction of flow from each cell to its downslope neighbor. Several methods are available. The most commonly used method is D8, which assigns direction based on a cell’s steepest downslope neighbor (using the 8 surrounding cells). The MFD method is more complex, generating a raster that is visualized the same as a D8 raster but with more complex metadata that is incorporated into later operations. The DINF method assigns the steepest downslope neighbor based on a triangular facet. The Force all edge cells to flow outward option addresses how to deal with edge effects. This option should usually remain unchecked, but if planning to run a basin analysis, this option should be checked. The input raster should be either a DEM or the modified DEM output from the Fill tool.","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"rMiBLkq4Dt"}],"key":"CfoY2CCwjU"},{"type":"heading","depth":2,"position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"Flow Accumulation","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"xYKND6cudM"}],"identifier":"flow-accumulation","label":"Flow Accumulation","html_id":"flow-accumulation","implicit":true,"key":"GV2IwrhGID"},{"type":"paragraph","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"The ","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"l63qJM41fM"},{"type":"link","url":"https://pro.arcgis.com/en/pro-app/3.3/tool-reference/spatial-analyst/flow-accumulation.htm","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"Flow Accumulation tool","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"i8R22LdIsQ"}],"urlSource":"https://pro.arcgis.com/en/pro-app/3.3/tool-reference/spatial-analyst/flow-accumulation.htm","key":"LSOSZRRtUp"},{"type":"text","value":" takes the flow direction raster as an input and creates a raster surface that shows accumulated flow into each cell. The appropriate flow direction type should match the method used to generate the flow direction raster in the previous step.","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"Zt7T3Dgxqh"}],"key":"nWZz1aqxOr"},{"type":"image","url":"/flowacc-599cb3bbff0b77d5afb5d3407c6bad30.jpg","alt":"Flow Accumulation","width":"80%","align":"center","class":"bg-primary mb-1","key":"gzK1L4zDaJ","urlSource":"/images/flowacc.jpg"},{"type":"paragraph","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"text","value":"The flow accumulation raster shows a stream network; however, the default visualization may not show enough detail. The symbology can be manually classified into two categories, and a threshold value selected to reveal the desired order of streams; this may take some trial and error. The following image shows the stream network with 5 categories over a geometric interval:","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"SMCi84Zc0v"}],"key":"B80WAP6Yzm"},{"type":"image","url":"/flowacc1-1e1039b54ca0125e99bdf13a4c8b6683.jpg","alt":"Flow Accumulation","width":"80%","align":"center","class":"bg-primary mb-1","key":"n6rcxPkMcd","urlSource":"/images/flowacc1.jpg"},{"type":"paragraph","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"children":[{"type":"text","value":"We can reclassify to the following:","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"FkXd1EwvmA"}],"key":"i6q7vRx2qg"},{"type":"image","url":"/flowacc2-112c4c9efa67daf2f54d020c438f1c9d.jpg","alt":"Flow Accumulation","width":"80%","align":"center","class":"bg-primary mb-1","key":"L1OfN61n14","urlSource":"/images/flowacc2.jpg"},{"type":"paragraph","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"children":[{"type":"text","value":"And we can convert to polylines using the ","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"key":"ePxnQTOkDj"},{"type":"link","url":"https://pro.arcgis.com/en/pro-app/latest/tool-reference/conversion/raster-to-polyline.htm","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"children":[{"type":"text","value":"Raster to Polyline tool","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"key":"wUejjtVsFQ"}],"urlSource":"https://pro.arcgis.com/en/pro-app/latest/tool-reference/conversion/raster-to-polyline.htm","key":"DsDEt7Sqmy"}],"key":"BvYJQshFRz"},{"type":"image","url":"/flowacc5-8c63f9309fd72f5188a8acc9ccb56708.jpg","alt":"Flow Accumulation","width":"80%","align":"center","class":"bg-primary mb-1","key":"RRyjgmq6jv","urlSource":"/images/flowacc5.jpg"},{"type":"paragraph","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"children":[{"type":"text","value":"If we want higher order streams, we can change the classification and generate a new polyline feature class:","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"key":"FPOVzRtZjp"}],"key":"r5FgOvCstt"},{"type":"image","url":"/flowacc3-bc8b92bce5350b0