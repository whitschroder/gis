{"version":3,"kind":"Article","sha256":"6e522b356f9654574ccddf99df97db75a1c367269edf4df93aa84733596f165e","slug":"cell","location":"/cell.md","dependencies":[],"frontmatter":{"title":"Cell Statistics and Map Algebra","content_includes_title":false,"github":"https://github.com/whitschroder/gis","keywords":["GIS","archaeology"],"numbering":{"title":{"offset":1}},"thumbnail":"/distance1-b8265f5c59d3d6a8a9b96350a81d0564.jpg","exports":[{"format":"md","filename":"cell.md","url":"/cell-ba5a737c73945bb7071a3fa4d61b7127.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Map algebra is a fundamental concept in raster GIS, involving applying mathematical operations to one or more raster layers. In this technique, raster layers can be treated like variables in algebra to apply arithmetic, including addition, subtraction, division, averaging, etc.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"KRbr7Poe47"}],"key":"mVLHJb64cY"},{"type":"heading","depth":2,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Cell Statistics","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"JDZ0GOp94s"}],"identifier":"cell-statistics","label":"Cell Statistics","html_id":"cell-statistics","implicit":true,"key":"l05veEl0Cs"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"The ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"mrjYIYYnZv"},{"type":"link","url":"https://pro.arcgis.com/en/pro-app/3.3/tool-reference/spatial-analyst/cell-statistics.htm","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Cell Statistics tool","position":{"start":{"line":7,"column":1},"end":{"line":7,"colu