e to one of these two sites:","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"u1tEAQPNdL"}],"key":"G3IP4n2XeI"},{"type":"image","url":"/distance3-4978616d458b61a4658dbaa5da4a16e2.jpg","alt":"Distance","width":"80%","align":"center","class":"bg-primary mb-1","key":"nmp9Zx8R25","urlSource":"/images/distance3.jpg"},{"type":"paragraph","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"Alternatively, we could run Cell Statistics set to maximum, to determine the maximum distance to either of these two sites:","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"iBoUnnFkwC"}],"key":"gIzVt8CevP"},{"type":"image","url":"/distance4-09ad5f6c0ecf73474286ee8f649fc499.jpg","alt":"Distance","width":"80%","align":"center","class":"bg-primary mb-1","key":"YJyllUeFmy","urlSource":"/images/distance4.jpg"},{"type":"paragraph","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"children":[{"type":"text","value":"Or the mean:","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"mxeJYU3fAG"}],"key":"Ud1CZrGGk5"},{"type":"image","url":"/distance5-4f050153b5c76a6aba46ef1e9ff6c1f1.jpg","alt":"Distance","width":"80%","align":"center","class":"bg-primary mb-1","key":"BSe4RpQGR0","urlSource":"/images/distance5.jpg"},{"type":"heading","depth":2,"position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"children":[{"type":"text","value":"Raster Calculator","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"cDRtG6tvGS"}],"identifier":"raster-calculator","label":"Raster Calculator","html_id":"raster-calculator","implicit":true,"key":"Gdzz6YWTeh"},{"type":"paragraph","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"children":[{"type":"text","value":"The Cell Statistics tool has a limited number of mathematical operations. The ","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"key":"lMwJaI0WXo"},{"type":"link","url":"https://pro.arcgis.com/en/pro-app/3.3/tool-reference/spatial-analyst/raster-calculator.htm","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"children":[{"type":"text","value":"Raster Calculator tool","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"key":"UzfhD8YYeB"}],"urlSource":"https://pro.arcgis.com/en/pro-app/3.3/tool-reference/spatial-analyst/raster-calculator.htm","key":"l1MoUAP0VE"},{"type":"text","value":" provides more flexibility in defining such operations.","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"key":"grjQmmSLgT"}],"key":"RcTrocgswb"},{"type":"paragraph","position":{"start":{"line":58,"column":1},"end":{"line":58,"column":1}},"children":[{"type":"text","value":"To illustrate, we can combine the following raster layers. The first layer represents architecture with values ranging from 1 to 13 over a background of 0:","position":{"start":{"line":58,"column":1},"end":{"line":58,"column":1}},"key":"y4X8wTA1zO"}],"key":"X2tzJcDFMa"},{"type":"image","url":"/rcinput1-679d88a3d8246c3184ebaffa3e802dca.jpg","alt":"Raster Calculator","width":"80%","align":"center","class":"bg-primary mb-1","key":"K74sNc1b9q","urlSource":"/images/rcinput1.jpg"},{"type":"paragraph","position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"children":[{"type":"text","value":"The second layer represents a road with a value of 14 over a background of 0:","position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"key":"igRWupOFs1"}],"key":"R2PFbgetSg"},{"type":"image","url":"/rcinput2-3e7c2bca861e46401607d48505a891fc.jpg","alt":"Raster Calculator","width":"80%","align":"center","class":"bg-primary mb-1","key":"G7JhAx9f4X","urlSource":"/images/rcinput2.jpg"},{"type":"paragraph","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"We could run the Cell Statistics tool with the statistic set to sum, or we could run Raster Calculator with the following formula, adding these two layers together:","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"smTcKApGkk"}],"key":"Dnw0X9DBbS"},{"type":"image","url":"/rc-2a8b381f0ba602d75fbdd6293d4e4091.jpg","alt":"Raster Calculator","width":"50%","align":"center","class":"bg-primary mb-1","key":"YdtTw9qkiG","urlSource":"/images/rc.jpg"},{"type":"paragraph","position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"children":[{"type":"text","value":"Doing so, we generate an output where 0 still represents the background, 1 to 13 still represent mounds, 14 still represents the road, but we now have additional values 15 and 27 that represent areas where the road overlaps architecture. In the case of 15, we have areas where the road overlaps the architecture with the value of 1, and in the case of 27, we have areas where the road overlaps the architecture with a value of 13:","position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"key":"XoUjv4IzHF"}],"key":"RS3PlVW8CJ"},{"type":"image","url":"/rcoutput-1f32d695376479d7d613a8cdfb1054c3.jpg","alt":"Raster Calculator","width":"80%","align":"center","class":"bg-primary mb-1","key":"DWe8art4Qd","urlSource":"/images/rcoutput.jpg"},{"type":"paragraph","position":{"start":{"line":94,"column":1},"end":{"line":94,"column":1}},"children":[{"type":"text","value":"We can also set Boolean operations, or true/false operations. If we run the following operation on the above output:","position":{"start":{"line":94,"column":1},"end":{"line":94,"column":1}},"key":"Hv7aXxAOCN"}],"key":"XdQiVH4pSS"},{"type":"code","lang":"","value":"\"input.tif\"  <= 14","position":{"start":{"line":96,"column":1},"end":{"line":98,"column":1}},"key":"Yu2AmjTosu"},{"type":"paragraph","position":{"start":{"line":100,"column":1},"end":{"line":100,"column":1}},"children":[{"type":"text","value":"We get an image where values less than or equal to 14 have been set 1, and values above 14 have been set to 0, separating areas where the road crosses architecture:","position":{"start":{"line":100,"column":1},"end":{"line":100,"column":1}},"key":"cM0QEzWMnD"}],"key":"rJmh7R8zY7"},{"type":"image","url":"/rcoutput2-7901704eaacaa2d0e1998c0400023da5.jpg","alt":"Raster Calculator","width":"80%","align":"center","class":"bg-primary mb-1","key":"RmGSZ2QDU8","urlSource":"/images/rcoutput2.jpg"},{"type":"paragraph","position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"children":[{"type":"text","value":"We can also set conditional statements. The following operation defines a conditional statement that where values in the DEM are less than 300, they should be set to 0, otherwise all other values should keep the same value in the raster.","position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"key":"Tlr39VZREY"}],"key":"taajRxkB67"},{"type":"code","lang":"","value":"Con(\"dem.tif\" < 300, 0, \"dem.tif\")","position":{"start":{"line":111,"column":1},"end":{"line":113,"column":1}},"key":"ABAD5ydOjj"},{"type":"paragraph","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"children":[{"type":"text","value":"When applied to the following DEM:","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"key":"a7mbwB7IuB"}],"key":"tLpI0ILENa"},{"type":"image","url":"/demcon1-19f8261033b9b5aeb85f2a73ad1981a2.jpg","alt":"Conditional","width":"80%","align":"center","class":"bg-primary mb-1","key":"DS3w5z9vJ3","urlSource":"/images/demcon1.jpg"},{"type":"paragraph","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"children":[{"type":"text","value":"We get the following output:","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"sDnwDWPp19"}],"key":"V0xFm9sZhE"},{"type":"image","url":"/demcon2-4f1c522d920ad244dad16545e629b67a.jpg","alt":"Conditional","width":"80%","align":"center","class":"bg-primary mb-1","key":"MoBqkx6FyE","urlSource":"/images/demcon2.jpg"},{"type":"paragraph","position":{"start":{"line":133,"column":1},"end":{"line":133,"column":1}},"children":[{"type":"text","value":"We can also use a conditional statement to replace NoData values with values from another raster. In the following example, we are filling the voids of a 1-arc second SRTM DEM with the values from a void-filled 3-arc second SRTM DEM. If we set the cell size under Environments to Minimum of Inputs, the output raster will be resampled to 1-arc second resolution.","position":{"start":{"line":133,"column":1},"end":{"line":133,"column":1}},"key":"cbdzgNnDLu"}],"key":"mBdlVwjQQB"},{"type":"code","lang":"","value":"Con(IsNull(\"1arc_dem.tif\") , \"3arc_dem.tif\", \"1arc_dem.tif\")","position":{"start":{"line":135,"column":1},"end":{"line":137,"column":1}},"key":"Nzs7Z45elB"},{"type":"paragraph","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"children":[{"type":"text","value":"Stated in plain English, this conditional statement can be read as “When the 1-arc second DEM has NoData, replace these values with those from the 3-arc second DEM, otherwise keep the 1-arc second DEM.”","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"key":"qAOgBHhKU9"}],"key":"sS5IkkgxNO"},{"type":"paragraph","position":{"start":{"line":141,"column":1},"end":{"line":141,"column":1}},"children":[{"type":"text","value":"The following raster layer represents the 1-arc second SRTM DEM with voids:","position":{"start":{"line":141,"column":1},"end":{"line":141,"column":1}},"key":"bPPzHXUW0H"}],"key":"rrnTTL0Dqr"},{"type":"image","url":"/conditional-e32507a18f795f7805bdfb955665252e.jpg","alt":"Conditional","width":"80%","align":"center","class":"bg-primary mb-1","key":"QwnJnhNIol","urlSource":"/images/conditional.jpg"},{"type":"paragraph","position":{"start":{"line":150,"column":1},"end":{"line":150,"column":1}},"children":[{"type":"text","value":"And the result of the raster calculator operation:","position":{"start":{"line":150,"column":1},"end":{"line":150,"column":1}},"key":"r5waqgrZzx"}],"key":"lyfphqE2tJ"},{"type":"image","url":"/conditional2-8918e047cb30778a9588356fc574e8f1.jpg","alt":"Conditional","width":"80%","align":"center","class":"bg-primary mb-1","key":"vY49WCzYLY","urlSource":"/images/conditional2.jpg"}],"key":"BjGquY60UQ"}],"key":"lPX79zdR0S"},"references":{"cite":{"order":[],"data":{}}}}