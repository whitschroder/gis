{"version":3,"kind":"Article","sha256":"d45ed4e956298fcdc742fe87b03fccaab61f18f3c6e755d65bdb008f39d4b91e","slug":"install","location":"/install.md","dependencies":[],"frontmatter":{"title":"Software","content_includes_title":false,"github":"https://github.com/whitschroder/gis","keywords":["GIS","archaeology"],"exports":[{"format":"md","filename":"install.md","url":"/install-753ed59ef7c89fd9c03ae8791ff56da5.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"ArcGIS Pro","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"qGRL86HdEw"}],"identifier":"arcgis-pro","label":"ArcGIS Pro","html_id":"arcgis-pro","implicit":true,"key":"hTnV1aWAsE"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"ArcGIS Pro is available for download from the UF Geoplan Center ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"A5K112RqmI"},{"type":"link","url":"https://www.geoplan.ufl.edu/software/arcgis-pro/","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"here","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"hromJe9amk"}],"urlSource":"https://www.geoplan.ufl.edu/software/arcgis-pro/","key":"H7fQOTtIG3"},{"type":"text","value":". You will need to be on the UF network or use the ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"I7EP8NRH9W"},{"type":"link","url":"https://it.ufl.edu/get-help/infrastructure/network-infrastructure/vpn/","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Gatorlink VPN","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"QZVZzFSPoW"}],"urlSource":"https://it.ufl.edu/get-help/infrastructure/network-infrastructure/vpn/","key":"Ldefw1BBx3"},{"type":"text","value":". When downloading the installation file, select the most recent version. Open the installation file and complete the installation steps using the default settings. During the installation, you may be prompted to update Microsoft .NET Desktop Runtime. Click on the link provided in the pop-up window, and download the specific version listed (currently version 10.0, x64). Once you open ArcGIS Pro after installation, you might be prompted to install an update. Click on the link and follow the installation process again.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"sUPvi3Jfqg"}],"key":"OHlex3dP8g"},{"type":"heading","depth":2,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Bootcamp","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"Ku8lpXvPxt"}],"identifier":"bootcamp","label":"Bootcamp","html_id":"bootcamp","implicit":true,"key":"ZLzfTuQmDw"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"For Mac users, ArcGIS Pro can be run through a Windows partition (e.g. Bootcamp) with an additional purchase of Windows. Additional information is available ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"FGNHSR36k9"},{"type":"link","url":"https://pro.arcgis.com/en/pro-app/latest/get-started/run-pro-on-a-mac.htm","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"here","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"GRBpjgYckf"}],"urlSource":"https://pro.arcgis.com/en/pro-app/latest/get-started/run-pro-on-a-mac.htm","key":"YDVAfRar31"},{"type":"text","value":".","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"HTacnmMLG0"}],"key":"UhWq2U8xqk"},{"type":"heading","depth":2,"position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"UF Apps","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"Hq6VajB8Cz"}],"identifier":"uf-apps","label":"UF Apps","html_id":"uf-apps","implicit":true,"key":"ziGlMdXIUP"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"For Mac and Windows users, ArcGIS Pro can be run through ","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"iBbfuTgdMg"},{"type":"link","url":"https://info.apps.ufl.edu/","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"UF Apps","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"mk5Bh7WS8n"}],"urlSource":"https://info.apps.ufl.edu/","key":"KZ8c5SDxRO"},{"type":"text","value":". Login to UF Apps and select either the Native Client or the HTML access. If you choose the former, you will have to download and install the Horizon Client. If using the HTML access, select UFApps Graphics. To open ArcGIS Pro on UF Apps, click the Windows button at the bottom center and search for ArcGIS Pro, then open. When prompted with the ArcGIS Sign In window, choose the “Your ArcGIS organization’s URL option.” Type ufl in the box (the full url should be ","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"WL6omrSEvT"},{"type":"link","url":"http://ufl.maps.arcgis.com","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"ufl.maps.arcgis.com","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"xPLzXS2Buj"}],"urlSource":"http://ufl.maps.arcgis.com","key":"nJMrFGYXGH"},{"type":"text","value":"). Click Continue. To manage files, you will have to use the M Drive, accessible from the virtual desktop. To upload files to the M Drive, click on the side bar to the left, and the Open File Transfer panel at the top of the side bar. Click Upload, and Choose Files. To download files to your computer from the M Drive, click Download, then open a new window with your M Drive, navigate to the file you want to transfer, select it, and click CTRL + C or COMMAND + C. The file should appear in the File Transfer panel, click the download arrow, and select the download location. Transferring files is easier with the Horizon Client. Open the M Drive in the Horizon Client and open a separate file folder on your local computer. Highlight and drag the files from your local computer to the M Drive.","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"UHDJ2FgWwQ"}],"key":"uYaiG2LhPy"},{"type":"heading","depth":2,"position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"QGIS","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"C6NvtDzWeq"}],"identifier":"qgis","label":"QGIS","html_id":"qgis","implicit":true,"key":"IHu602PLO8"},{"type":"paragraph","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"For Windows or Mac users, QGIS is a good alternative to ArcGIS Pro. QGIS can be downloaded for free ","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"KGsBz3TuV2"},{"type":"link","url":"https://qgis.org/download/","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"here","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"aHl05shizr"}],"urlSource":"https://qgis.org/download/","key":"EeY0TEf9JA"},{"type":"text","value":". Select the long-term version based on your platform. Once downloaded, run the installer with default settings. QGIS includes several in house tools, but additional plugins are available under Plugins -> Manage and Install Plugins.","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"aUdtp70SvW"}],"key":"kXh82OT2Cn"},{"type":"heading","depth":2,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"SAGA","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"Ad53IzSo0b"}],"identifier":"saga","label":"SAGA","html_id":"saga","implicit":true,"key":"DRxENweUNw"},{"type":"paragraph","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"SAGA is a GIS software that was previously integrated with QGIS. If using QGIS on Windows, SAGA is still available by installing the Processing Saga NextGen Provider, available under Plugins -> Manage and Install Plugins. Then in QGIS go to Settings -> Options -> Processing, and under Providers and SAGANG, choose the SAGA folder where SAGA is installed. In Windows, the folder should be something like C:\\Program Files\\QGIS 3.44.12\\apps\\saga, but this will depend on your specific QGIS installation.","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"Nu7D0ileGb"}],"key":"KcPpo6WGED"},{"type":"paragraph","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"If using QGIS on a Mac, you will need to install SAGA separately ","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"KUz5U6p4yj"},{"type":"link","url":"https://sourceforge.net/projects/saga-gis","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"here","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"xRQIhdmBSd"}],"urlSource":"https://sourceforge.net/projects/saga-gis","key":"RDq2yVZf5L"},{"type":"text","value":". Once installed, open the zip file and copy the SAGA application to Applications. The Processing Saga NextGen Provider plugin is not available in QGIS on a Mac. However, you can run SAGA as a standalone interface. To use SAGA, you have to open your input file by clicking the folder icon at top left. Then under tools, select the appropriate tool. You can also search for the tool by name by clicking the gear icon. In the search box, type the name of the tool, click anywhere, then click Okay. When running each tool, you have to provide the name of the input file (which first has to be opened with the folder icon). Next to any outputs, select ","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"DEU89QymRd"},{"type":"text","value":". Then select any parameters under Options. Click Okay to run the tool. The output if successful, will be available under Data at the top left. Click the data and then click the save icon to export the file (change file type to GeoTIFF). This file can then be loaded into QGIS.","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"lgU6GRLzcW"}],"key":"bUYihEVmWq"},{"type":"heading","depth":2,"position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"GRASS","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"pXknZgqrMl"}],"identifier":"grass","label":"GRASS","html_id":"grass","implicit":true,"key":"kAALYgL9Qa"},{"type":"paragraph","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"In Windows, GRASS should be automatically included in QGIS. You may need to install or activate (clicking the check box) the GRASS Processing Provider from Plugins -> Manage and Install Plugins.","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"PXmzo8fUdH"}],"key":"BPc91GZRYj"},{"type":"paragraph","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"On a Mac, you will need to install GRASS separately ","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"anZdCurO1M"},{"type":"link","url":"https://grass.osgeo.org/download/mac","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"here","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"wgW89im1t1"}],"urlSource":"https://grass.osgeo.org/download/mac","key":"vKFTXlAqKE"},{"type":"text","value":". Install GRASS 8.4.2 (legacy) based on your operating system. Once installed, copy GRASS to your Applications.","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"p5QXzSLhHp"}],"key":"kjY6SFEu2T"},{"type":"paragraph","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"To activate GRASS in QGIS, go to Settings -> Options, click on System, and under Environment, check the box next to Use custom variables. Click the plus sign to add variables. You will need to add the following three variables:","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"nwxeg0vY5Z"}],"key":"mxsr4F5O7R"},{"type":"table","position":{"start":{"line":33,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"tableRow","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"tableCell","header":true,"position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"Apply","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"ElekLvWZhl"}],"key":"nnTs4xa1MF"},{"type":"tableCell","header":true,"position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"Variable","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"qc8c42ob8k"}],"key":"DTEJiI404a"},{"type":"tableCell","header":true,"position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"Value","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"YbqObY6Izy"}],"key":"FJ2exeNEp1"}],"key":"hOMYh6EhG1"},{"type":"tableRow","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"Prepend","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"tbTLsQybAb"}],"key":"UEFfC55Ffo"},{"type":"tableCell","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"GRASS_PREFIX","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"Yr3LhwxpSb"}],"key":"YdOnR7H4pU"},{"type":"tableCell","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"/Applications/GRASS-8.4.app/Contents/Resources","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"vmoYCpCELu"}],"key":"KkqTTAtPS0"}],"key":"v6oOVwmupg"},{"type":"tableRow","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"Prepend","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"SHbuJCVhlW"}],"key":"LlFXx2WFWE"},{"type":"tableCell","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"GISBASE","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"WLOViJEOYW"}],"key":"SCKi28hA4N"},{"type":"tableCell","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"/Applications/GRASS-8.4.app/Contents/Resources","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"N2n4Q12Bw6"}],"key":"tKR8CSdjA9"}],"key":"FzWGzavHZt"},{"type":"tableRow","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"Prepend","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"oC2K13WJke"}],"key":"hABAz8hUAc"},{"type":"tableCell","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"PROJ_NETWORK","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"j1BLR6wsLL"}],"key":"JBwq53N5Na"},{"type":"tableCell","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"ON","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"N4ojoW3Gbc"}],"key":"yAO6Tg6GkE"}],"key":"OnxEGgBGUN"}],"key":"JVLX0E0ZMc"},{"type":"paragraph","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"text","value":"Then click OK. Restart QGIS, and you should now see the GRASS tools in the Processing Toolbox.","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"XDQ8j8hlk2"}],"key":"uAq3DNNToT"},{"type":"paragraph","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"children":[{"type":"text","value":"If GRASS is not working in QGIS, GRASS can be opened as its own standalone software similar to SAGA.","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"XgiqKBg7dr"}],"key":"jV3WvhnTxp"},{"type":"heading","depth":2,"position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"children":[{"type":"text","value":"Whitebox Workflows","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"C0ikZqmRs6"}],"identifier":"whitebox-workflows","label":"Whitebox Workflows","html_id":"whitebox-workflows","implicit":true,"key":"qHlcG3cnV3"},{"type":"paragraph","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"children":[{"type":"text","value":"To use Whitebox Workflows in QGIS, go to Plugins -> Manage and Install Plugins, search for Whitebox Workflows for QGIS, and install. You may need to restart QGIS after installing the plugin. Next go to Plugins -> Whitebox Workflows -> Check Backend Updates. Currently, the installation of backend updates is leading to errors on some devices.","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"V629QiPtxL"}],"key":"JQQH3jTr0p"}],"key":"ieCJtBJIMi"}],"key":"mxz51HgqqX"},"references":{"cite":{"order":[],"data":{}}}}