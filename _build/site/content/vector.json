{"version":3,"kind":"Article","sha256":"89e85cc285efccdfb024bf0fb67d953cfca67104d164e7a777309f19fbdd6c46","slug":"vector","location":"/vector.md","dependencies":[],"frontmatter":{"title":"Editing Vector Data","content_includes_title":false,"github":"https://github.com/whitschroder/gis","keywords":["GIS","archaeology"],"numbering":{"title":{"offset":1}},"thumbnail":"/edit-e9b36ebe4552bc0e9d5cb0de26a0a7ce.jpg","exports":[{"format":"md","filename":"vector.md","url":"/vector-bdb6cb2b5040ca5c3170ac653a3895a9.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Vector data in the form of a shapefile or feature class can be edited in GIS software.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"FFJTdDtPF8"}],"key":"JNdEcFGVuq"},{"type":"heading","depth":2,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Editing in ArcGIS Pro","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"jGVkTyLrH5"}],"identifier":"editing-in-arcgis-pro","label":"Editing in ArcGIS Pro","html_id":"editing-in-arcgis-pro","implicit":true,"key":"KBbuXz3AVj"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Vector data can be edited in ArcGIS Pro under the Edit toolbar. To edit a vector layer, click Edit -> Create Features. In the Create Features pane select the feature class you want to edit. For point data, the options are straightforward. For example, under your layer in the Create Features pane, click Point. Then click anywhere in the map to place your point. For lines, you can click Line to draw a simple line or explore the other options to draw right angles, arcs, etc. Polygons have similar options.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"XAtrLNDkOy"}],"key":"ymm02l3T7G"},{"type":"image","url":"/edit-e9b36ebe4552bc0e9d5cb0de26a0a7ce.jpg","alt":"Edit","width":"80%","align":"center","class":"bg-primary mb-1","key":"Vxe7S3KgTa","urlSource":"/images/edit.jpg"},{"type":"paragraph","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Once a feature has been placed, you must save your edits or discard them. These options are available under the Edit toolbar. Note that the button to save edits is not the same as the button to save the project. If you exit out of your project with unsaved edits, the program will prompt you to save or discard them, but it is best practice to save often.","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"AZuUkoJfaD"}],"key":"SbtAtDorwk"},{"type":"image","url":"/saveedit-35f0e56d87e9fc167e27e9e8f000f773.jpg","alt":"Save Edits","width":"80%","align":"center","class":"bg-primary mb-1","key":"ckI4U9oGoA","urlSource":"/images/saveedit.jpg"},{"type":"paragraph","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"To create a new, empty vector layer, navigate to the Catalog pane, choose a folder and right-click to select New -> Shapefile, or if working in a geodatabase, New -> Feature Class. You will be presented with additional parameters, including assigning a Feature Class Name, Geometry Type, and a Coordinate System. The new shapefile will be automatically added to Contents, which can then be edited like any other vector layer.","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"GjaDaLkeAC"}],"key":"PitAdMXLui"},{"type":"image","url":"/newfeature-0b39040ff32b4eb1ea5d818c6e9edb18.jpg","alt":"New Feature","width":"80%","align":"center","class":"bg-primary mb-1","key":"Or4gpjfrvk","urlSource":"/images/newfeature.jpg"},{"type":"paragraph","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"text","value":"Snapping can be turned on or off under the Edit toolbar. When on, your cursor will snap to another feature when nearby.","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"O4wuhxVmrg"}],"key":"CgXVXu2fle"},{"type":"paragraph","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"Additional tools are available under the Editor Tool Gallery.","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"KfJcSB4j2C"}],"key":"zV7gu0Njxp"},{"type":"image","url":"/toolgallery-df4823319184dae82e278b99892a8fa8.jpg","alt":"Tool Gallery","width":"80%","align":"center","class":"bg-primary mb-1","key":"ywrX5phxf5","urlSource":"/images/toolgallery.jpg"},{"type":"paragraph","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"children":[{"type":"text","value":"Additional information on editing feature classes is available ","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"v1muvXOgID"},{"type":"link","url":"https://pro.arcgis.com/en/pro-app/latest/help/editing/a-quick-tour-of-editing.htm","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"children":[{"type":"text","value":"here","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"ZmShx107gp"}],"urlSource":"https://pro.arcgis.com/en/pro-app/latest/help/editing/a-quick-tour-of-editing.htm","key":"Yys4MKc9lX"},{"type":"text","value":".","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"IBsRugjeHr"}],"key":"hyR9wpsOAp"},{"type":"heading","depth":2,"position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"Editing in QGIS","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"K85HJwkSOR"}],"identifier":"editing-in-qgis","label":"Editing in QGIS","html_id":"editing-in-qgis","implicit":true,"key":"cSbhqLmRiU"},{"type":"paragraph","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"Editing shapefiles in QGIS is similar to ArcGIS Pro. More information is available ","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"bwaf2yJ7mv"},{"type":"link","url":"https://docs.qgis.org/3.34/en/docs/user_manual/working_with_vector/editing_geometry_attributes.html","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"here","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"R6Ozr9EETn"}],"urlSource":"https://docs.qgis.org/3.34/en/docs/user_manual/working_with_vector/editing_geometry_attributes.html","key":"rK2vxUCSon"},{"type":"text","value":".","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"wUZECnFm9k"}],"key":"d8kB7MAa5U"}],"key":"Hm0EPPlDzj"}],"key":"fiV5enQAtD"},"references":{"cite":{"order":[],"data":{}}}}