{"version":3,"kind":"Article","sha256":"2110358c8c1e1a815a4bd92451513eb242b3f71158c96263c8d9e6b7d17c9077","slug":"georeference","location":"/georeference.md","dependencies":[],"frontmatter":{"title":"Georeferencing","content_includes_title":false,"github":"https://github.com/whitschroder/gis","keywords":["GIS","archaeology"],"numbering":{"title":{"offset":1}},"thumbnail":"/georeferencetab-d9cefca9823d9c52db822c18d8196581.jpg","exports":[{"format":"md","filename":"georeference.md","url":"/georeference-351009a098db3120ac8c8bb23069efd2.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Any imagery can be added to ArcGIS Pro through the Add Data option. However, imagery that do not have any spatial reference will be placed randomly in the map frame. Adding a spatial reference to imagery is called Georeferencing. Examples of imagery that can be georeferenced are maps produced outside of GIS (including sketch maps, historical maps, etc.) or aerial imagery.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"v2Kyw4PlUx"}],"key":"mUCSziDcit"},{"type":"heading","depth":2,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Georeferencing in ArcGIS Pro","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"NY9S21sCY3"}],"identifier":"georeferencing-in-arcgis-pro","label":"Georeferencing in ArcGIS Pro","html_id":"georeferencing-in-arcgis-pro","implicit":true,"key":"Wi2CPl5gyQ"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"To georeferenced imagery in ArcGIS Pro, select the relevant raster layer in Contents and click Imagery -> Georeference.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"eY7ncSuJy1"}],"key":"XObcJtmByn"},{"type":"image","url":"/georeferencetab-d9cefca9823d9c52db822c18d8196581.jpg","alt":"Georeference","width":"80%","align":"center","class":"bg-primary mb-1","key":"KmDJtYaZi5","urlSource":"/images/georeferencetab.jpg"},{"type":"paragraph","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"The simplest georeferencing tools are available under Georeference -> Prepare. Fit to Display will relocate the imagery to the current viewing extent of the map frame. Move, Scale, and Rotate will adjust the extent and orientation of the imagery.","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"NKZpaW3kOq"}],"key":"Ex3lks1K3e"},{"type":"paragraph","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"More precise tools are available under Georeference -> Adjust. Add Control Points involves selecting a point on the imagery followed by selecting the spatial location of that point on the map frame. To delete a control point, click Georeference -> Review -> Control Point Table, select the record and click Delete Selected.","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"SyGkkjZJgk"}],"key":"A0T4LvqcPv"},{"type":"paragraph","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"At least 3 control points should be positioned. Under Georeference -> Adjust -> Transformation, you can select the transformation used to stretch or drape the imagery. Polynomials are the simplest transformation, but with at least 10 points you can select the Spline transformation, which will be the most accurate and lead to less overall error. The Auto Apply button will update the map on the fly. The imagery can be turned off and on in Contents to assist with the georeferencing, or under Raster Layer -> Transparency, you can make the layer transparent.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"CFBqog0Kos"}],"key":"M9wTdQkN0i"},{"type":"paragraph","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"Once satisfied with the edits, click Georeference -> Save or Georeference -> Save as New (the latter to save a new file rather than overriding the original. Note that this save button differs from the Save Project button at the top left. Then click Close Georeference.","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"mMNkEtpjq9"}],"key":"SUdJrhNI8B"},{"type":"paragraph","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"text","value":"Additional instructions are available at ","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"jC0vAIuU96"},{"type":"link","url":"https://pro.arcgis.com/en/pro-app/latest/help/data/imagery/georeferencing-tools.htm","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"text","value":"Georeferencing Tools","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"rCAyaAABqq"}],"urlSource":"https://pro.arcgis.com/en/pro-app/latest/help/data/imagery/georeferencing-tools.htm","key":"HnizjbFTgv"},{"type":"text","value":".","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"h94gBQutMY"}],"key":"Sni2gCIsPu"},{"type":"heading","depth":2,"position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"text","value":"Georeferencing in QGIS","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"nJxG9HL7NW"}],"identifier":"georeferencing-in-qgis","label":"Georeferencing in QGIS","html_id":"georeferencing-in-qgis","implicit":true,"key":"aBBnCYVWz7"},{"type":"paragraph","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"text","value":"The workflow to georeference imagery in QGIS is similar. Instructions are available at the ","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"UsZ7WYNcr1"},{"type":"link","url":"https://docs.qgis.org/3.34/en/docs/user_manual/working_with_raster/georeferencer.html","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"text","value":"Georeferencer","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"aAbtvKe0Vs"}],"urlSource":"https://docs.qgis.org/3.34/en/docs/user_manual/working_with_raster/georeferencer.html","key":"sNSyZGTJfG"},{"type":"text","value":".","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"G9prluvXBy"}],"key":"LQhgs6Gh1k"}],"key":"cxfVVdxzac"}],"key":"yWxt9UCbfs"},"references":{"cite":{"order":[],"data":{}}}}